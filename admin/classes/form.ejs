<%- include('../../partials/header', { title: typeof pageTitle !=='undefined' ? pageTitle : 'Classe' , session: typeof
    session !=='undefined' ? session : null }) %>

    <% var safeClass=typeof academicClass !=='undefined' && academicClass ? academicClass : {}; var
        safeCampuses=Array.isArray(campuses) ? campuses : []; var safeDepartments=Array.isArray(departments) ?
        departments : []; var safePrograms=Array.isArray(programs) ? programs : []; var isEdit=Boolean(safeClass &&
        safeClass.id); var backUrl=isEdit ? '/admin/classes/' + safeClass.id : '/admin/classes' ; function
        safeText(value, fallback) { if (value===null || typeof value==='undefined' || value==='' ) { return fallback
        || '' ; } return value; } function selected(value, expected) { return String(value || '' )===String(expected
        || '' ) ? 'selected' : '' ; } function campusLabel(campus) { if (!campus) return 'Campus' ; var parts=[]; if
        (campus.nom) parts.push(campus.nom); if (campus.code) parts.push(campus.code); return parts.join(' — ');
    }

    function departmentLabel(department) {
        if (!department) return ' Département'; var parts=[]; if (department.nom) parts.push(department.nom); if
        (department.code) parts.push(department.code); if (department.campus && department.campus.nom)
        parts.push(department.campus.nom); return parts.join(' — ');
    }

    function programLabel(program) {
        if (!program) return ' Programme'; var parts=[]; if (program.filiere) parts.push(program.filiere); if
        (program.niveau) parts.push(program.niveau); return parts.join(' ');
    }
%>

<div class="cs-back-row">
    <a class="cs-back-link" href="<%= backUrl %>">
        ← <%= isEdit ? ' Retour à la fiche classe' : 'Retour aux classes' %>
        </a>
        </div>

        <section class="cs-admin-list-hero">
            <div>
                <span class="page-kicker">Module Classes</span>

                <h1>
                    <%= pageTitle || (isEdit ? 'Modifier la classe' : 'Nouvelle classe' ) %>
                </h1>

                <p>
                    Créez ou modifiez une classe en respectant la hiérarchie officielle :
                    campus, département académique, programme et année universitaire.
                </p>
            </div>

            <div class="cs-admin-list-actions">
                <% if (isEdit) { %>
                    <a class="btn btn-secondary" href="/admin/classes/<%= safeClass.id %>">
                        Voir la fiche
                    </a>
                    <% } %>

                        <a class="btn btn-secondary" href="/admin/classes">
                            Liste classes
                        </a>
            </div>
        </section>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-error">
                <%= error %>
            </div>
            <% } %>

                <form class="cs-class-form" method="POST" action="<%= formAction %>">
                    <%- include('../../partials/csrf') %>

                        <section class="cs-form-layout">
                            <div class="cs-form-main">
                                <article class="cs-form-card">
                                    <div class="cs-form-card-head">
                                        <div>
                                            <h2>Identification de la classe</h2>
                                            <p>Nom, code et année universitaire de référence.</p>
                                        </div>
                                    </div>

                                    <div class="cs-form-grid">
                                        <div class="cs-form-field">
                                            <label for="nom">Nom de la classe *</label>
                                            <input id="nom" name="nom" type="text"
                                                value="<%= safeText(safeClass.nom, '') %>" placeholder="Ex : INF L2 A"
                                                autocomplete="off" required>
                                            <p>Nom lisible utilisé dans les listes et les fiches.</p>
                                        </div>

                                        <div class="cs-form-field">
                                            <label for="code">Code classe</label>
                                            <input id="code" name="code" type="text"
                                                value="<%= safeText(safeClass.code, '') %>"
                                                placeholder="Ex : INF-L2A-BDL" autocomplete="off">
                                            <p>Facultatif, mais recommandé pour les imports et la recherche.</p>
                                        </div>

                                        <div class="cs-form-field">
                                            <label for="academicYear">Année universitaire *</label>
                                            <input id="academicYear" name="academicYear" type="text"
                                                value="<%= safeText(safeClass.academicYear, '2025-2026') %>"
                                                placeholder="Ex : 2025-2026" autocomplete="off" required>
                                            <p>Format conseillé : 2025-2026.</p>
                                        </div>
                                    </div>
                                </article>

                                <article class="cs-form-card">
                                    <div class="cs-form-card-head">
                                        <div>
                                            <h2>Rattachement académique</h2>
                                            <p>
                                                Une classe appartient à un campus, un département académique et un
                                                programme.
                                            </p>
                                        </div>
                                    </div>

                                    <div class="cs-form-grid">
                                        <div class="cs-form-field">
                                            <label for="campusId">Campus *</label>
                                            <select id="campusId" name="campusId" required>
                                                <option value="">Sélectionner un campus</option>

                                                <% safeCampuses.forEach(function(campus) { %>
                                                    <option value="<%= campus.id %>" <%=selected(safeClass.campusId,
                                                        campus.id) %>
                                                        >
                                                        <%= campusLabel(campus) %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <p>Un ADMIN_CAMPUS ne voit que son campus autorisé.</p>
                                        </div>

                                        <div class="cs-form-field">
                                            <label for="departmentId">Département *</label>
                                            <select id="departmentId" name="departmentId" required>
                                                <option value="">Sélectionner un département</option>

                                                <% safeDepartments.forEach(function(department) { %>
                                                    <option value="<%= department.id %>"
                                                        data-campus-id="<%= department.campusId || '' %>"
                                                        <%=selected(safeClass.departmentId, department.id) %>
                                                        >
                                                        <%= departmentLabel(department) %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <p>Le département doit appartenir au campus choisi.</p>
                                        </div>

                                        <div class="cs-form-field">
                                            <label for="programId">Programme *</label>
                                            <select id="programId" name="programId" required>
                                                <option value="">Sélectionner un programme</option>

                                                <% safePrograms.forEach(function(program) { %>
                                                    <option value="<%= program.id %>" <%=selected(safeClass.programId,
                                                        program.id) %>
                                                        >
                                                        <%= programLabel(program) %>
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <p>Le programme représente la filière et le niveau.</p>
                                        </div>
                                    </div>
                                </article>

                                <article class="cs-form-card">
                                    <div class="cs-form-card-head">
                                        <div>
                                            <h2>Résumé avant validation</h2>
                                            <p>Vérifiez la cohérence avant d’enregistrer.</p>
                                        </div>
                                    </div>

                                    <div class="cs-class-form-preview" id="classPreview">
                                        <div>
                                            <span>Classe</span>
                                            <strong data-preview="nom">
                                                <%= safeText(safeClass.nom, 'Non défini' ) %>
                                            </strong>
                                        </div>

                                        <div>
                                            <span>Code</span>
                                            <strong data-preview="code">
                                                <%= safeText(safeClass.code, 'Non défini' ) %>
                                            </strong>
                                        </div>

                                        <div>
                                            <span>Année</span>
                                            <strong data-preview="academicYear">
                                                <%= safeText(safeClass.academicYear, 'Non défini' ) %>
                                            </strong>
                                        </div>

                                        <div>
                                            <span>Campus</span>
                                            <strong data-preview="campus">À sélectionner</strong>
                                        </div>

                                        <div>
                                            <span>Département</span>
                                            <strong data-preview="department">À sélectionner</strong>
                                        </div>

                                        <div>
                                            <span>Programme</span>
                                            <strong data-preview="program">À sélectionner</strong>
                                        </div>
                                    </div>
                                </article>
                            </div>

                            <aside class="cs-form-side">
                                <article class="cs-form-help-card">
                                    <div class="cs-form-help-icon">🏫</div>

                                    <h2>
                                        <%= isEdit ? 'Modification classe' : 'Création classe' %>
                                    </h2>

                                    <% if (isEdit) { %>
                                        <p>
                                            Modifier une classe peut impacter les étudiants, les affectations,
                                            les imports et les notes liées à cette classe.
                                        </p>
                                        <% } else { %>
                                            <p>
                                                Une classe devient ensuite le hub permettant d’accéder aux étudiants,
                                                professeurs, notes et affectations.
                                            </p>
                                            <% } %>
                                </article>

                                <article class="cs-form-help-card">
                                    <div class="cs-form-help-icon">🧭</div>

                                    <h2>Règle métier</h2>

                                    <p>
                                        Badalabougou et Torokoubougou sont des campus/sites.
                                        Les départements sont académiques : Informatique, Gestion, Droit, etc.
                                    </p>
                                </article>

                                <article class="cs-form-help-card">
                                    <div class="cs-form-help-icon">🛡️</div>

                                    <h2>Contrôle campus</h2>

                                    <p>
                                        Le serveur vérifie que le département choisi appartient bien au campus
                                        sélectionné.
                                        Le scope ADMIN_CAMPUS reste appliqué côté contrôleur.
                                    </p>
                                </article>

                                <article class="cs-form-actions-card">
                                    <button class="btn btn-primary" type="submit">
                                        <%= submitLabel || (isEdit ? 'Enregistrer' : 'Créer la classe' ) %>
                                    </button>

                                    <a class="btn btn-secondary" href="<%= backUrl %>">
                                        Annuler
                                    </a>
                                </article>
                            </aside>
                        </section>
                </form>

                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        const campusSelect = document.getElementById('campusId');
                        const departmentSelect = document.getElementById('departmentId');
                        const programSelect = document.getElementById('programId');
                        const nomInput = document.getElementById('nom');
                        const codeInput = document.getElementById('code');
                        const yearInput = document.getElementById('academicYear');

                        const departmentOptions = departmentSelect
                            ? Array.from(departmentSelect.options)
                            : [];

                        function getSelectedText(select) {
                            if (!select || !select.value) {
                                return 'À sélectionner';
                            }

                            const option = select.options[select.selectedIndex];

                            return option ? option.textContent.trim() : 'À sélectionner';
                        }

                        function setPreview(name, value) {
                            const element = document.querySelector('[data-preview="' + name + '"]');

                            if (!element) return;

                            element.textContent = value && String(value).trim()
                                ? String(value).trim()
                                : 'Non défini';
                        }

                        function syncDepartmentsWithCampus() {
                            if (!campusSelect || !departmentSelect) return;

                            const selectedCampusId = campusSelect.value;

                            departmentOptions.forEach(function (option) {
                                if (!option.value) {
                                    option.hidden = false;
                                    return;
                                }

                                const optionCampusId = option.getAttribute('data-campus-id');
                                const shouldShow = !selectedCampusId || optionCampusId === selectedCampusId;

                                option.hidden = !shouldShow;

                                if (!shouldShow && option.selected) {
                                    departmentSelect.value = '';
                                }
                            });
                        }

                        function syncPreview() {
                            setPreview('nom', nomInput ? nomInput.value : '');
                            setPreview('code', codeInput ? codeInput.value : '');
                            setPreview('academicYear', yearInput ? yearInput.value : '');
                            setPreview('campus', getSelectedText(campusSelect));
                            setPreview('department', getSelectedText(departmentSelect));
                            setPreview('program', getSelectedText(programSelect));
                        }

                        if (campusSelect && campusSelect.options.length === 2 && !campusSelect.value) {
                            campusSelect.selectedIndex = 1;
                        }

                        [campusSelect, departmentSelect, programSelect, nomInput, codeInput, yearInput].forEach(function (field) {
                            if (!field) return;

                            field.addEventListener('input', function () {
                                syncDepartmentsWithCampus();
                                syncPreview();
                            });

                            field.addEventListener('change', function () {
                                syncDepartmentsWithCampus();
                                syncPreview();
                            });
                        });

                        syncDepartmentsWithCampus();
                        syncPreview();
                    });
                </script>

                <%- include('../../partials/footer') %>