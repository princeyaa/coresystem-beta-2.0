<%- include('../../partials/header', {
    title: typeof pageTitle !== 'undefined' ? pageTitle : 'Cours / Matiere',
    session: typeof session !== 'undefined' ? session : null
}) %>

<%
    var c = typeof course !== 'undefined' && course ? course : {};
    var safePrograms = Array.isArray(programs) ? programs : [];
    var isEdit = Boolean(c && c.id);
    var backUrl = '/admin/courses';

    function safeText(value, fallback) {
        if (value === null || typeof value === 'undefined' || value === '') {
            return fallback || '';
        }

        return value;
    }

    function selected(value, expected) {
        return String(value || '') === String(expected || '') ? 'selected' : '';
    }

    function programLabel(program) {
        if (!program) return 'Programme';

        var parts = [];

        if (program.filiere) parts.push(program.filiere);
        if (program.niveau) parts.push(program.niveau);
        if (program.faculte) parts.push(program.faculte);

        return parts.join(' - ') || 'Programme';
    }
%>

<div class="cs-back-row">
    <a class="cs-back-link" href="<%= backUrl %>">
        &larr; Retour aux cours
    </a>
</div>

<section class="cs-admin-list-hero">
    <div>
        <span class="page-kicker">Module Cours / Matieres</span>

        <h1><%= pageTitle || (isEdit ? 'Modifier le cours' : 'Nouveau cours') %></h1>

        <p>
            Un cours appartient a un programme. Il porte le semestre, les credits,
            le coefficient et le volume horaire utilises dans les notes, affectations et emplois du temps.
        </p>
    </div>

    <div class="cs-admin-list-actions">
        <a class="btn btn-secondary" href="/admin/courses">
            Liste des cours
        </a>
    </div>
</section>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
        <%= error %>
    </div>
<% } %>

<form class="cs-course-form" method="POST" action="<%= formAction %>">
    <%- include('../../partials/csrf') %>

    <section class="cs-form-layout">
        <div class="cs-form-main">
            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Identification du cours</h2>
                        <p>Code, nom et rattachement au programme.</p>
                    </div>
                </div>

                <div class="cs-form-grid">
                    <div class="cs-form-field">
                        <label for="code">Code du cours *</label>
                        <input
                            id="code"
                            name="code"
                            type="text"
                            value="<%= safeText(c.code, '') %>"
                            placeholder="Ex : INFO201"
                            autocomplete="off"
                            required
                        >
                        <p>Le code doit rester unique pour les recherches et les imports.</p>
                    </div>

                    <div class="cs-form-field">
                        <label for="nom">Nom du cours *</label>
                        <input
                            id="nom"
                            name="nom"
                            type="text"
                            value="<%= safeText(c.nom, '') %>"
                            placeholder="Ex : Bases de donnees"
                            autocomplete="off"
                            required
                        >
                    </div>

                    <div class="cs-form-field">
                        <label for="programId">Programme *</label>
                        <select id="programId" name="programId" required>
                            <option value="">Selectionner un programme</option>

                            <% safePrograms.forEach(function(program) { %>
                                <option
                                    value="<%= program.id %>"
                                    <%= selected(c.programId, program.id) %>
                                >
                                    <%= programLabel(program) %>
                                </option>
                            <% }) %>
                        </select>
                        <p>Le programme determine la filiere et le niveau concernes.</p>
                    </div>
                </div>
            </article>

            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Parametres pedagogiques</h2>
                        <p>Semestre, volume horaire, credits et coefficient.</p>
                    </div>
                </div>

                <div class="cs-form-grid">
                    <div class="cs-form-field">
                        <label for="semestre">Semestre *</label>
                        <input
                            id="semestre"
                            name="semestre"
                            type="text"
                            value="<%= safeText(c.semestre, '') %>"
                            placeholder="Ex : S1"
                            autocomplete="off"
                            required
                        >
                        <p>Exemples : S1, S2, S3, S4.</p>
                    </div>

                    <div class="cs-form-field">
                        <label for="credits">Credits *</label>
                        <input
                            id="credits"
                            name="credits"
                            type="number"
                            min="0"
                            step="1"
                            value="<%= safeText(c.credits, '') %>"
                            placeholder="Ex : 4"
                            required
                        >
                    </div>

                    <div class="cs-form-field">
                        <label for="coefficient">Coefficient *</label>
                        <input
                            id="coefficient"
                            name="coefficient"
                            type="number"
                            min="0"
                            step="0.1"
                            value="<%= safeText(c.coefficient, '') %>"
                            placeholder="Ex : 2"
                            required
                        >
                    </div>

                    <div class="cs-form-field">
                        <label for="volumeHoraire">Volume horaire</label>
                        <input
                            id="volumeHoraire"
                            name="volumeHoraire"
                            type="number"
                            min="0"
                            step="1"
                            value="<%= safeText(c.volumeHoraire, '') %>"
                            placeholder="Ex : 40"
                        >
                        <p>Facultatif. Laisser vide si non defini.</p>
                    </div>

                    <div class="cs-form-field cs-form-field-wide-local">
                        <label for="enseignant">Enseignant indicatif</label>
                        <input
                            id="enseignant"
                            name="enseignant"
                            type="text"
                            value="<%= safeText(c.enseignant, '') %>"
                            placeholder="Ex : Dr Traore"
                            autocomplete="off"
                        >
                        <p>
                            Champ indicatif. La vraie relation professeur-cours-classe se gere dans les affectations.
                        </p>
                    </div>
                </div>
            </article>

            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Resume avant validation</h2>
                        <p>Verifiez la coherence avant d'enregistrer.</p>
                    </div>
                </div>

                <div class="cs-course-preview">
                    <div>
                        <span>Code</span>
                        <strong data-preview="code"><%= safeText(c.code, 'Non defini') %></strong>
                    </div>

                    <div>
                        <span>Cours</span>
                        <strong data-preview="nom"><%= safeText(c.nom, 'Non defini') %></strong>
                    </div>

                    <div>
                        <span>Programme</span>
                        <strong data-preview="program">A selectionner</strong>
                    </div>

                    <div>
                        <span>Semestre</span>
                        <strong data-preview="semestre"><%= safeText(c.semestre, 'Non defini') %></strong>
                    </div>

                    <div>
                        <span>Credits</span>
                        <strong data-preview="credits"><%= safeText(c.credits, 'Non defini') %></strong>
                    </div>

                    <div>
                        <span>Coefficient</span>
                        <strong data-preview="coefficient"><%= safeText(c.coefficient, 'Non defini') %></strong>
                    </div>
                </div>
            </article>
        </div>

        <aside class="cs-form-side">
            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">CO</div>

                <h2>
                    <%= isEdit ? 'Modification cours' : 'Creation cours' %>
                </h2>

                <p>
                    Le cours decrit la matiere. Il ne remplace pas l'affectation pedagogique
                    qui relie professeur, classe, cours et annee universitaire.
                </p>
            </article>

            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">AF</div>

                <h2>Affectations</h2>

                <p>
                    Apres creation du cours, utilisez le module Affectations pour relier ce cours
                    a un professeur et a une classe.
                </p>
            </article>

            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">NT</div>

                <h2>Impact notes</h2>

                <p>
                    Les notes utilisent le cours comme matiere de reference.
                    Evitez de modifier lourdement un cours deja utilise par des notes.
                </p>
            </article>

            <article class="cs-form-actions-card">
                <button class="btn btn-primary" type="submit">
                    <%= submitLabel || (isEdit ? 'Enregistrer' : 'Creer le cours') %>
                </button>

                <a class="btn btn-secondary" href="<%= backUrl %>">
                    Annuler
                </a>
            </article>
        </aside>
    </section>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var codeInput = document.getElementById('code');
        var nomInput = document.getElementById('nom');
        var programSelect = document.getElementById('programId');
        var semestreInput = document.getElementById('semestre');
        var creditsInput = document.getElementById('credits');
        var coefficientInput = document.getElementById('coefficient');

        function getSelectedText(select) {
            if (!select || !select.value) {
                return 'A selectionner';
            }

            var option = select.options[select.selectedIndex];

            return option ? option.textContent.trim() : 'A selectionner';
        }

        function setPreview(name, value) {
            var element = document.querySelector('[data-preview="' + name + '"]');

            if (!element) return;

            element.textContent = value && String(value).trim()
                ? String(value).trim()
                : 'Non defini';
        }

        function syncPreview() {
            setPreview('code', codeInput ? codeInput.value : '');
            setPreview('nom', nomInput ? nomInput.value : '');
            setPreview('program', getSelectedText(programSelect));
            setPreview('semestre', semestreInput ? semestreInput.value : '');
            setPreview('credits', creditsInput ? creditsInput.value : '');
            setPreview('coefficient', coefficientInput ? coefficientInput.value : '');
        }

        [codeInput, nomInput, programSelect, semestreInput, creditsInput, coefficientInput].forEach(function (field) {
            if (!field) return;

            field.addEventListener('input', syncPreview);
            field.addEventListener('change', syncPreview);
        });

        syncPreview();
    });
</script>

<%- include('../../partials/footer') %>
