<%- include('../../partials/header', {
    title: 'Cours / Matieres',
    session: typeof session !== 'undefined' ? session : null
}) %>

<%
    var safeCourses = Array.isArray(courses) ? courses : [];

    var totalCourses = safeCourses.length;
    var totalSchedules = 0;
    var totalGrades = 0;
    var totalAssignments = 0;

    var semesters = [];
    var programLabels = [];

    safeCourses.forEach(function(course) {
        var counts = course._count || {};

        totalSchedules += Number(counts.schedules || 0);
        totalGrades += Number(counts.grades || 0);
        totalAssignments += Number(counts.teachingAssignments || 0);

        if (course.semestre && semesters.indexOf(course.semestre) === -1) {
            semesters.push(course.semestre);
        }

        if (course.program) {
            var pLabel = ((course.program.filiere || '') + ' ' + (course.program.niveau || '')).trim();

            if (pLabel && programLabels.indexOf(pLabel) === -1) {
                programLabels.push(pLabel);
            }
        }
    });

    semesters.sort();
    programLabels.sort();

    function safeText(value, fallback) {
        if (value === null || typeof value === 'undefined' || value === '') {
            return fallback || '-';
        }

        return value;
    }

    function courseInitials(course) {
        if (!course || !course.code) {
            return 'CO';
        }

        return String(course.code).replace(/[^a-zA-Z0-9]/g, '').slice(0, 3).toUpperCase() || 'CO';
    }

    function programLabel(course) {
        if (!course || !course.program) {
            return 'Programme non defini';
        }

        return [
            course.program.filiere || '',
            course.program.niveau || ''
        ].join(' ').trim() || 'Programme non defini';
    }

    function programMeta(course) {
        if (!course || !course.program) {
            return '-';
        }

        return course.program.faculte || course.program.regime || '-';
    }

    function countOf(course, key) {
        if (!course || !course._count) {
            return 0;
        }

        return Number(course._count[key] || 0);
    }
%>

<section class="cs-admin-list-hero">
    <div>
        <span class="page-kicker">Module Cours / Matieres</span>

        <h1>Cours / Matieres</h1>

        <p>
            Gere les matieres, semestres, coefficients, credits et volumes horaires.
            Le cours decrit la matiere ; l'affectation relie professeur, cours, classe et annee.
        </p>
    </div>

    <div class="cs-admin-list-actions">
        <a class="btn btn-primary" href="/admin/courses/new">
            Nouveau cours
        </a>
    </div>
</section>

<div class="cs-list-kpi-row">
    <article class="cs-list-kpi">
        <div class="cs-list-kpi-icon">CO</div>
        <div>
            <strong><%= totalCourses %></strong>
            <span>Cours affiches</span>
        </div>
    </article>

    <article class="cs-list-kpi">
        <div class="cs-list-kpi-icon">AF</div>
        <div>
            <strong><%= totalAssignments %></strong>
            <span>Affectations</span>
        </div>
    </article>

    <article class="cs-list-kpi">
        <div class="cs-list-kpi-icon">NT</div>
        <div>
            <strong><%= totalGrades %></strong>
            <span>Notes liees</span>
        </div>
    </article>

    <article class="cs-list-kpi">
        <div class="cs-list-kpi-icon">ED</div>
        <div>
            <strong><%= totalSchedules %></strong>
            <span>Creneaux</span>
        </div>
    </article>
</div>

<section class="cs-filter-panel">
    <div class="cs-filter-panel-head">
        <div>
            <h2>Recherche et filtres</h2>
            <p>
                Filtrez rapidement les cours affiches par nom, code, programme ou semestre.
            </p>
        </div>

        <button class="cs-filter-reset" type="button" id="courseResetFilters">
            Reinitialiser
        </button>
    </div>

    <form class="cs-course-filter-form cs-student-filter-form" onsubmit="return false;">
        <div class="cs-filter-field cs-filter-field-wide">
            <label for="courseSearch">Recherche</label>
            <input
                id="courseSearch"
                type="text"
                placeholder="Code, nom, programme, enseignant..."
                autocomplete="off"
            >
        </div>

        <div class="cs-filter-field">
            <label for="courseSemesterFilter">Semestre</label>
            <select id="courseSemesterFilter">
                <option value="">Tous les semestres</option>

                <% semesters.forEach(function(semestre) { %>
                    <option value="<%= semestre %>">
                        <%= semestre %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="cs-filter-field">
            <label for="courseProgramFilter">Programme</label>
            <select id="courseProgramFilter">
                <option value="">Tous les programmes</option>

                <% programLabels.forEach(function(label) { %>
                    <option value="<%= label %>">
                        <%= label %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="cs-filter-field">
            <label for="courseUsageFilter">Utilisation</label>
            <select id="courseUsageFilter">
                <option value="">Tous</option>
                <option value="withAssignments">Avec affectation</option>
                <option value="withoutAssignments">Sans affectation</option>
                <option value="withGrades">Avec notes</option>
                <option value="withSchedules">Avec creneaux</option>
            </select>
        </div>
    </form>

    <div class="cs-active-filter-list" id="courseActiveFilters" style="display: none;"></div>
</section>

<section class="cs-table-card">
    <div class="cs-table-card-head">
        <div>
            <h2>Liste des cours</h2>
            <p>
                <span id="courseVisibleCount"><%= safeCourses.length %></span>
                resultat<span id="coursePlural"><%= safeCourses.length > 1 ? 's' : '' %></span>
                affiche<span id="coursePlural2"><%= safeCourses.length > 1 ? 's' : '' %></span>.
            </p>
        </div>

        <span class="cs-table-count" id="courseTableCount"><%= safeCourses.length %></span>
    </div>

    <% if (!safeCourses.length) { %>
        <div class="empty-state" style="margin: 18px;">
            <div class="empty-state-icon">∅</div>
            <h2>Aucun cours trouve</h2>
            <p>Aucun cours n'est encore disponible dans votre perimetre.</p>
        </div>
    <% } else { %>
        <div class="table-responsive">
            <table class="cs-table cs-courses-table">
                <thead>
                    <tr>
                        <th>Cours</th>
                        <th>Programme</th>
                        <th>Pedagogie</th>
                        <th>Affectations</th>
                        <th>Notes</th>
                        <th>Creneaux</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% safeCourses.forEach(function(course) {
                        var assignmentsCount = countOf(course, 'teachingAssignments');
                        var gradesCount = countOf(course, 'grades');
                        var schedulesCount = countOf(course, 'schedules');
                        var searchText = [
                            course.code || '',
                            course.nom || '',
                            course.semestre || '',
                            course.enseignant || '',
                            programLabel(course),
                            programMeta(course)
                        ].join(' ').toLowerCase();
                    %>
                        <tr
                            class="cs-course-row"
                            data-search="<%= searchText %>"
                            data-semester="<%= safeText(course.semestre, '') %>"
                            data-program="<%= programLabel(course) %>"
                            data-assignments="<%= assignmentsCount %>"
                            data-grades="<%= gradesCount %>"
                            data-schedules="<%= schedulesCount %>"
                        >
                            <td>
                                <div class="cs-entity-cell">
                                    <div class="cs-entity-avatar">
                                        <%= courseInitials(course) %>
                                    </div>

                                    <div class="cs-entity-main">
                                        <a class="cs-entity-title cs-course-title-link" href="/admin/courses/<%= course.id %>/edit">
                                            <%= safeText(course.code, 'CODE') %> - <%= safeText(course.nom, 'Cours') %>
                                        </a>

                                        <span class="cs-entity-subtitle">
                                            Enseignant indicatif : <%= safeText(course.enseignant, 'Non defini') %>
                                        </span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="cs-cell-strong">
                                    <%= programLabel(course) %>
                                </div>

                                <div class="cs-cell-muted">
                                    <%= programMeta(course) %>
                                </div>
                            </td>

                            <td>
                                <div class="cs-course-metric-stack">
                                    <span>Semestre : <strong><%= safeText(course.semestre, '-') %></strong></span>
                                    <span>Credits : <strong><%= safeText(course.credits, '-') %></strong></span>
                                    <span>Coef. : <strong><%= safeText(course.coefficient, '-') %></strong></span>
                                    <span>Volume : <strong><%= safeText(course.volumeHoraire, '-') %> h</strong></span>
                                </div>
                            </td>

                            <td>
                                <a class="cs-cell-strong cs-course-title-link" href="/admin/assignments?courseId=<%= course.id %>">
                                    <%= assignmentsCount %> affectation<%= assignmentsCount > 1 ? 's' : '' %>
                                </a>

                                <div class="cs-cell-muted">
                                    Professeurs et classes
                                </div>
                            </td>

                            <td>
                                <a class="cs-cell-strong cs-course-title-link" href="/admin/grades?courseId=<%= course.id %>">
                                    <%= gradesCount %> note<%= gradesCount > 1 ? 's' : '' %>
                                </a>

                                <div class="cs-cell-muted">
                                    Resultats associes
                                </div>
                            </td>

                            <td>
                                <div class="cs-cell-strong">
                                    <%= schedulesCount %> creneau<%= schedulesCount > 1 ? 'x' : '' %>
                                </div>

                                <div class="cs-cell-muted">
                                    Emploi du temps
                                </div>
                            </td>

                            <td>
                                <details class="cs-action-dropdown">
                                    <summary>Actions</summary>

                                    <div class="cs-action-menu">
                                        <a href="/admin/courses/<%= course.id %>/edit">
                                            Modifier
                                        </a>

                                        <a href="/admin/assignments?courseId=<%= course.id %>">
                                            Voir les affectations
                                        </a>

                                        <a href="/admin/grades?courseId=<%= course.id %>">
                                            Voir les notes
                                        </a>

                                        <form method="POST" action="/admin/courses/<%= course.id %>/delete">
                                            <%- include('../../partials/csrf') %>

                                            <button
                                                class="cs-danger-action"
                                                type="submit"
                                                data-confirm="Supprimer ce cours ? Cette action sera bloquee si le cours est deja lie a des notes, creneaux ou affectations."
                                            >
                                                Supprimer
                                            </button>
                                        </form>
                                    </div>
                                </details>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var searchInput = document.getElementById('courseSearch');
        var semesterFilter = document.getElementById('courseSemesterFilter');
        var programFilter = document.getElementById('courseProgramFilter');
        var usageFilter = document.getElementById('courseUsageFilter');
        var resetButton = document.getElementById('courseResetFilters');
        var activeFilters = document.getElementById('courseActiveFilters');
        var rows = Array.prototype.slice.call(document.querySelectorAll('.cs-course-row'));
        var visibleCount = document.getElementById('courseVisibleCount');
        var tableCount = document.getElementById('courseTableCount');
        var plural = document.getElementById('coursePlural');
        var plural2 = document.getElementById('coursePlural2');

        function valueOf(element) {
            return element ? String(element.value || '').trim() : '';
        }

        function lower(value) {
            return String(value || '').toLowerCase();
        }

        function matchesUsage(row, usage) {
            var assignments = Number(row.getAttribute('data-assignments') || 0);
            var grades = Number(row.getAttribute('data-grades') || 0);
            var schedules = Number(row.getAttribute('data-schedules') || 0);

            if (!usage) return true;
            if (usage === 'withAssignments') return assignments > 0;
            if (usage === 'withoutAssignments') return assignments === 0;
            if (usage === 'withGrades') return grades > 0;
            if (usage === 'withSchedules') return schedules > 0;

            return true;
        }

        function renderActiveFilters(query, semester, program, usage) {
            var html = '';

            if (query) {
                html += '<span>Recherche : <strong>' + query + '</strong></span>';
            }

            if (semester) {
                html += '<span>Semestre : <strong>' + semester + '</strong></span>';
            }

            if (program) {
                html += '<span>Programme : <strong>' + program + '</strong></span>';
            }

            if (usage) {
                html += '<span>Utilisation : <strong>' + usage + '</strong></span>';
            }

            if (activeFilters) {
                activeFilters.innerHTML = html;
                activeFilters.style.display = html ? 'flex' : 'none';
            }
        }

        function applyFilters() {
            var query = lower(valueOf(searchInput));
            var semester = valueOf(semesterFilter);
            var program = valueOf(programFilter);
            var usage = valueOf(usageFilter);
            var count = 0;

            rows.forEach(function (row) {
                var rowText = lower(row.getAttribute('data-search') || '');
                var rowSemester = row.getAttribute('data-semester') || '';
                var rowProgram = row.getAttribute('data-program') || '';

                var show = true;

                if (query && rowText.indexOf(query) === -1) {
                    show = false;
                }

                if (semester && rowSemester !== semester) {
                    show = false;
                }

                if (program && rowProgram !== program) {
                    show = false;
                }

                if (!matchesUsage(row, usage)) {
                    show = false;
                }

                row.style.display = show ? '' : 'none';

                if (show) {
                    count += 1;
                }
            });

            if (visibleCount) visibleCount.textContent = String(count);
            if (tableCount) tableCount.textContent = String(count);
            if (plural) plural.textContent = count > 1 ? 's' : '';
            if (plural2) plural2.textContent = count > 1 ? 's' : '';

            renderActiveFilters(valueOf(searchInput), semester, program, usage);
        }

        [searchInput, semesterFilter, programFilter, usageFilter].forEach(function (field) {
            if (!field) return;

            field.addEventListener('input', applyFilters);
            field.addEventListener('change', applyFilters);
        });

        if (resetButton) {
            resetButton.addEventListener('click', function () {
                if (searchInput) searchInput.value = '';
                if (semesterFilter) semesterFilter.value = '';
                if (programFilter) programFilter.value = '';
                if (usageFilter) usageFilter.value = '';
                applyFilters();
            });
        }

        applyFilters();
    });
</script>

<%- include('../../partials/footer') %>
