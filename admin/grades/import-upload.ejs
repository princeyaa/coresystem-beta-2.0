<%- include('../../partials/header', {
    title: typeof pageTitle !== 'undefined' ? pageTitle : 'Import notes',
    session: typeof session !== 'undefined' ? session : null
}) %>

<%
    var safeClasses = Array.isArray(classes) ? classes : [];
    var safeSelectedClassId = typeof selectedClassId !== 'undefined' ? selectedClassId : '';
    var safeMaxRows = typeof maxRows !== 'undefined' ? maxRows : 3000;
    var safeCsvContent = typeof csvContent !== 'undefined' ? csvContent : '';
    var safeSheetSelection = typeof sheetSelection !== 'undefined' ? sheetSelection : null;
    var hasSheetSelection = safeSheetSelection && safeSheetSelection.requiresChoice;

    var selectedClass = null;

    safeClasses.forEach(function(item) {
        if (String(item.id || '') === String(safeSelectedClassId || '')) {
            selectedClass = item;
        }
    });

    function safeText(value, fallback) {
        if (value === null || typeof value === 'undefined' || value === '') {
            return fallback || '-';
        }

        return value;
    }

    function selected(value, expected) {
        return String(value || '') === String(expected || '') ? 'selected' : '';
    }

    function classLabel(item) {
        if (!item) return 'Classe';

        var parts = [];

        if (item.nom) parts.push(item.nom);
        if (item.code) parts.push(item.code);
        if (item.academicYear) parts.push(item.academicYear);
        if (item.campus && item.campus.nom) parts.push(item.campus.nom);

        return parts.join(' - ') || 'Classe';
    }
%>

<div class="cs-back-row">
    <a class="cs-back-link" href="<%= selectedClass ? '/admin/grades?classId=' + selectedClass.id : '/admin/grades' %>">
        &larr; Retour aux notes
    </a>
</div>

<section class="cs-admin-list-hero">
    <div>
        <span class="page-kicker">Module Notes</span>

        <h1>Import notes</h1>

        <p>
            Importez des notes depuis un fichier CSV ou Excel.
            CoreSystem analyse les lignes avant insertion et garde les notes importees en brouillon.
        </p>

        <% if (selectedClass) { %>
            <div class="cs-context-pill-row">
                <span class="cs-context-pill">
                    Classe : <strong><%= safeText(selectedClass.nom, '-') %></strong>
                </span>

                <span class="cs-context-pill">
                    Annee : <strong><%= safeText(selectedClass.academicYear, '-') %></strong>
                </span>
            </div>
        <% } %>
    </div>

    <div class="cs-admin-list-actions">
        <a class="btn btn-secondary" href="/admin/grades">
            Liste notes
        </a>

        <% if (selectedClass) { %>
            <a class="btn btn-secondary" href="/admin/classes/<%= selectedClass.id %>">
                Fiche classe
            </a>
        <% } %>
    </div>
</section>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
        <%= error %>
    </div>
<% } %>

<section class="cs-import-steps">
    <article class="cs-import-step is-active">
        <span>1</span>
        <div>
            <strong>Classe</strong>
            <small>Choix obligatoire</small>
        </div>
    </article>

    <article class="cs-import-step">
        <span>2</span>
        <div>
            <strong>Upload</strong>
            <small>CSV ou Excel</small>
        </div>
    </article>

    <article class="cs-import-step">
        <span>3</span>
        <div>
            <strong>Preview</strong>
            <small>Verification</small>
        </div>
    </article>

    <article class="cs-import-step">
        <span>4</span>
        <div>
            <strong>Rapport</strong>
            <small>Resultat final</small>
        </div>
    </article>
</section>

<section class="cs-import-layout">
    <div class="cs-import-main">
        <% if (hasSheetSelection) { %>
            <article class="cs-form-card cs-import-warning-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Choisir la feuille Excel</h2>
                        <p>
                            Le fichier <strong><%= safeText(safeSheetSelection.fileName, 'Excel') %></strong>
                            contient plusieurs feuilles. Selectionnez celle qui contient les notes.
                        </p>
                    </div>
                </div>

                <form method="POST" action="/admin/grades/import/preview" class="cs-import-sheet-form">
                    <%- include('../../partials/csrf') %>

                    <input type="hidden" name="usePendingFile" value="1">
                    <input type="hidden" name="classId" value="<%= safeSelectedClassId %>">

                    <div class="cs-form-field">
                        <label for="selectedSheetName">Feuille Excel *</label>

                        <select id="selectedSheetName" name="selectedSheetName" required>
                            <option value="">Selectionner une feuille</option>

                            <% safeSheetSelection.sheetNames.forEach(function(sheetName) { %>
                                <option
                                    value="<%= sheetName %>"
                                    <%= selected(safeSheetSelection.selectedSheetName, sheetName) %>
                                >
                                    <%= sheetName %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="cs-import-actions">
                        <button class="btn btn-primary" type="submit">
                            Previsualiser cette feuille
                        </button>

                        <a class="btn btn-secondary" href="/admin/grades/import<%= safeSelectedClassId ? '?classId=' + safeSelectedClassId : '' %>">
                            Annuler
                        </a>
                    </div>
                </form>
            </article>
        <% } %>

        <article class="cs-form-card">
            <div class="cs-form-card-head">
                <div>
                    <h2>Classe concernee</h2>
                    <p>
                        L'import des notes est strict : une classe doit etre selectionnee avant l'analyse.
                    </p>
                </div>
            </div>

            <form method="POST" action="/admin/grades/import/preview" enctype="multipart/form-data">
                <%- include('../../partials/csrf') %>

                <div class="cs-form-field">
                    <label for="classId">Classe *</label>

                    <select id="classId" name="classId" required>
                        <option value="">Selectionner une classe</option>

                        <% safeClasses.forEach(function(item) { %>
                            <option value="<%= item.id %>" <%= selected(safeSelectedClassId, item.id) %>>
                                <%= classLabel(item) %>
                            </option>
                        <% }) %>
                    </select>

                    <p>
                        Le fichier importera uniquement des notes pour la classe choisie.
                    </p>
                </div>

                <div class="cs-import-upload-box">
                    <div class="cs-import-upload-icon">NT</div>

                    <div>
                        <label for="importFile">Fichier CSV ou Excel</label>

                        <input
                            id="importFile"
                            name="importFile"
                            type="file"
                            accept=".csv,.xlsx"
                        >

                        <p>
                            Formats acceptes : .csv et .xlsx.
                            Si le fichier Excel contient plusieurs feuilles, CoreSystem demandera la feuille a utiliser.
                        </p>
                    </div>
                </div>

                <div class="cs-form-field cs-import-textarea-field">
                    <label for="csvContent">Contenu CSV optionnel</label>

                    <textarea
                        id="csvContent"
                        name="csvContent"
                        rows="12"
                        placeholder="matricule;courseCode;typeEvaluation;valeur&#10;2021001;INFO201;CC;14.5&#10;2021002;INFO201;PARTIEL;12"
                    ><%= safeCsvContent %></textarea>

                    <p>
                        Si un fichier est fourni, il est prioritaire. Sinon, CoreSystem analysera le CSV colle ici.
                    </p>
                </div>

                <div class="cs-import-actions">
                    <button class="btn btn-primary" type="submit">
                        Previsualiser l'import
                    </button>

                    <a class="btn btn-secondary" href="/admin/grades<%= safeSelectedClassId ? '?classId=' + safeSelectedClassId : '' %>">
                        Annuler
                    </a>
                </div>
            </form>
        </article>

        <article class="cs-form-card">
            <div class="cs-form-card-head">
                <div>
                    <h2>Format attendu</h2>
                    <p>
                        Ces colonnes permettent d'identifier l'etudiant, le cours, le type d'evaluation et la note.
                    </p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="cs-table cs-import-format-table">
                    <thead>
                        <tr>
                            <th>Colonne</th>
                            <th>Importance</th>
                            <th>Exemple</th>
                            <th>Role</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td><strong>matricule</strong></td>
                            <td><span class="badge badge-danger">Obligatoire</span></td>
                            <td>2021001</td>
                            <td>Identifie l'etudiant dans la classe selectionnee.</td>
                        </tr>

                        <tr>
                            <td><strong>courseCode</strong></td>
                            <td><span class="badge badge-danger">Obligatoire</span></td>
                            <td>INFO201</td>
                            <td>Code du cours dans le programme de la classe.</td>
                        </tr>

                        <tr>
                            <td><strong>typeEvaluation</strong></td>
                            <td><span class="badge badge-danger">Obligatoire</span></td>
                            <td>CC</td>
                            <td>Type de note : CC, PARTIEL, EXAMEN ou RATTRAPAGE.</td>
                        </tr>

                        <tr>
                            <td><strong>valeur</strong></td>
                            <td><span class="badge badge-danger">Obligatoire</span></td>
                            <td>14.5</td>
                            <td>Note comprise entre 0 et 20.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </article>
    </div>

    <aside class="cs-import-side">
        <article class="cs-form-help-card">
            <div class="cs-form-help-icon">CL</div>

            <h2>Classe obligatoire</h2>

            <p>
                L'import ne travaille jamais sans classe. Cela evite de melanger les notes entre plusieurs groupes.
            </p>
        </article>

        <article class="cs-form-help-card">
            <div class="cs-form-help-icon">BR</div>

            <h2>Brouillon par defaut</h2>

            <p>
                Les notes importees restent en brouillon. La publication se fait ensuite volontairement.
            </p>
        </article>

        <article class="cs-form-help-card">
            <div class="cs-form-help-icon">SEC</div>

            <h2>Protection</h2>

            <p>
                Les notes deja publiees sont protegees. Elles doivent etre depubliees avant un import massif.
            </p>
        </article>

        <article class="cs-form-help-card">
            <div class="cs-form-help-icon">MAX</div>

            <h2>Limite</h2>

            <p>
                Limite actuelle : <strong><%= safeMaxRows %> lignes</strong>.
            </p>
        </article>
    </aside>
</section>

<%- include('../../partials/footer') %>
