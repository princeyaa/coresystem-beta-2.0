<%- include('../../partials/header', {
    title: typeof pageTitle !== 'undefined' ? pageTitle : 'Annonce',
    session: typeof session !== 'undefined' ? session : null
}) %>

<%
    var a = typeof announcement !== 'undefined' && announcement ? announcement : {};
    var safePrograms = Array.isArray(programs) ? programs : [];
    var safePriorities = Array.isArray(allowedPriorities) ? allowedPriorities : ['NORMALE', 'IMPORTANTE', 'URGENTE'];
    var isEdit = Boolean(a && a.id);
    var backUrl = '/admin/announcements';

    function safeText(value, fallback) {
        if (value === null || typeof value === 'undefined' || value === '') {
            return fallback || '';
        }

        return value;
    }

    function selected(value, expected) {
        return String(value || '') === String(expected || '') ? 'selected' : '';
    }

    function priorityLabel(priority) {
        if (typeof helpers !== 'undefined' && helpers && helpers.formatEnumLabel) {
            return helpers.formatEnumLabel(priority);
        }

        return safeText(priority, '-');
    }

    function programLabel(program) {
        if (!program) return 'Programme';

        return [
            program.filiere || '',
            program.niveau || '',
            program.faculte ? '- ' + program.faculte : ''
        ].join(' ').trim() || 'Programme';
    }
%>

<div class="cs-back-row">
    <a class="cs-back-link" href="<%= backUrl %>">
        &larr; Retour aux annonces
    </a>
</div>

<section class="cs-admin-list-hero">
    <div>
        <span class="page-kicker">Module Annonces</span>

        <h1><%= pageTitle || (isEdit ? 'Modifier l’annonce' : 'Nouvelle annonce') %></h1>

        <p>
            Rédigez une annonce claire, officielle et utile pour les étudiants.
            Elle peut être générale ou ciblée vers un programme.
        </p>
    </div>

    <div class="cs-admin-list-actions">
        <a class="btn btn-secondary" href="/admin/announcements">
            Liste annonces
        </a>
    </div>
</section>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
        <%= error %>
    </div>
<% } %>

<form class="cs-announcement-form" method="POST" action="<%= formAction %>">
    <%- include('../../partials/csrf') %>

    <section class="cs-form-layout">
        <div class="cs-form-main">
            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Contenu de l’annonce</h2>
                        <p>Titre, priorité et message officiel.</p>
                    </div>
                </div>

                <div class="cs-form-grid cs-form-grid-2">
                    <div class="cs-form-field">
                        <label for="titre">Titre *</label>

                        <input
                            id="titre"
                            name="titre"
                            type="text"
                            value="<%= safeText(a.titre, '') %>"
                            placeholder="Ex : Rattrapage de mathématiques"
                            autocomplete="off"
                            required
                        >
                    </div>

                    <div class="cs-form-field">
                        <label for="priorite">Priorité *</label>

                        <select id="priorite" name="priorite" required>
                            <% safePriorities.forEach(function(priority) { %>
                                <option value="<%= priority %>" <%= selected(a.priorite || 'NORMALE', priority) %>>
                                    <%= priorityLabel(priority) %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="cs-form-field cs-announcement-content-field">
                    <label for="contenu">Contenu *</label>

                    <textarea
                        id="contenu"
                        name="contenu"
                        rows="8"
                        placeholder="Rédigez ici le contenu de l’annonce..."
                        required
                    ><%= safeText(a.contenu, '') %></textarea>

                    <p>
                        Restez précis : objet, date, classe ou programme concerné, consigne à suivre.
                    </p>
                </div>
            </article>

            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Ciblage et durée</h2>
                        <p>Définissez si l’annonce est générale ou liée à un programme.</p>
                    </div>
                </div>

                <div class="cs-form-grid cs-form-grid-2">
                    <div class="cs-form-field">
                        <label for="programId">Ciblage programme</label>

                        <select id="programId" name="programId">
                            <option value="">Annonce générale</option>

                            <% safePrograms.forEach(function(program) { %>
                                <option value="<%= program.id %>" <%= selected(a.programId, program.id) %>>
                                    <%= programLabel(program) %>
                                </option>
                            <% }) %>
                        </select>

                        <p>Laissez vide pour une annonce générale.</p>
                    </div>

                    <div class="cs-form-field">
                        <label for="expiresAt">Date d’expiration</label>

                        <input
                            id="expiresAt"
                            name="expiresAt"
                            type="date"
                            value="<%= safeText(a.expiresAt, '') %>"
                        >

                        <p>Après cette date, l’annonce ne doit plus apparaître côté étudiant.</p>
                    </div>
                </div>
            </article>

            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Résumé avant validation</h2>
                        <p>Contrôlez le rendu principal avant enregistrement.</p>
                    </div>
                </div>

                <div class="cs-announcement-preview">
                    <div>
                        <span>Titre</span>
                        <strong data-preview="titre"><%= safeText(a.titre, 'Non défini') %></strong>
                    </div>

                    <div>
                        <span>Priorité</span>
                        <strong data-preview="priorite"><%= priorityLabel(a.priorite || 'NORMALE') %></strong>
                    </div>

                    <div>
                        <span>Ciblage</span>
                        <strong data-preview="program">Annonce générale</strong>
                    </div>

                    <div>
                        <span>Expiration</span>
                        <strong data-preview="expiresAt"><%= safeText(a.expiresAt, 'Aucune') %></strong>
                    </div>
                </div>
            </article>
        </div>

        <aside class="cs-form-side">
            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">AN</div>

                <h2><%= isEdit ? 'Modification annonce' : 'Création annonce' %></h2>

                <p>
                    Les annonces doivent rester utiles : information courte, claire,
                    avec une priorité cohérente.
                </p>
            </article>

            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">PR</div>

                <h2>Ciblage</h2>

                <p>
                    Une annonce générale touche tout le monde. Une annonce ciblée ne concerne
                    que le programme sélectionné.
                </p>
            </article>

            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">EX</div>

                <h2>Expiration</h2>

                <p>
                    Utilisez une date d’expiration pour éviter que les anciennes annonces
                    restent visibles trop longtemps.
                </p>
            </article>

            <article class="cs-form-actions-card">
                <button class="btn btn-primary" type="submit">
                    <%= submitLabel || (isEdit ? 'Enregistrer' : 'Créer l’annonce') %>
                </button>

                <a class="btn btn-secondary" href="<%= backUrl %>">
                    Annuler
                </a>
            </article>
        </aside>
    </section>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var titleInput = document.getElementById('titre');
        var prioritySelect = document.getElementById('priorite');
        var programSelect = document.getElementById('programId');
        var expiresInput = document.getElementById('expiresAt');

        function setPreview(name, value) {
            var element = document.querySelector('[data-preview="' + name + '"]');

            if (!element) return;

            element.textContent = value && String(value).trim()
                ? String(value).trim()
                : 'Non défini';
        }

        function getSelectedText(select, fallback) {
            if (!select || !select.value) {
                return fallback || 'Non défini';
            }

            var option = select.options[select.selectedIndex];

            return option ? option.textContent.trim() : (fallback || 'Non défini');
        }

        function syncPreview() {
            setPreview('titre', titleInput ? titleInput.value : '');
            setPreview('priorite', getSelectedText(prioritySelect, 'Normale'));
            setPreview('program', getSelectedText(programSelect, 'Annonce générale'));
            setPreview('expiresAt', expiresInput && expiresInput.value ? expiresInput.value : 'Aucune');
        }

        [titleInput, prioritySelect, programSelect, expiresInput].forEach(function (field) {
            if (!field) return;

            field.addEventListener('input', syncPreview);
            field.addEventListener('change', syncPreview);
        });

        syncPreview();
    });
</script>

<%- include('../../partials/footer') %>