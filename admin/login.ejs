<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion administration - CoreSystem</title>

    <style>
        :root {
            --primary: #7467f0;
            --primary-dark: #5b4ee6;
            --text: #202638;
            --muted: #666b7d;
            --border: #d8dce7;
            --danger: #b91c1c;
            --danger-soft: #fee2e2;
            --white: #ffffff;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            font-family: "Segoe UI", Arial, sans-serif;
            color: var(--text);
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
            overflow: hidden;
            background:
                radial-gradient(circle at 72% 45%, rgba(0, 166, 255, 0.28), transparent 25%),
                radial-gradient(circle at 20% 80%, rgba(29, 78, 216, 0.22), transparent 24%),
                linear-gradient(135deg, #020a1d 0%, #031a3d 48%, #084572 100%);
            position: relative;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(120deg, rgba(56, 189, 248, 0.16) 1px, transparent 1px),
                linear-gradient(30deg, rgba(59, 130, 246, 0.14) 1px, transparent 1px);
            background-size: 150px 150px, 210px 210px;
            opacity: 0.55;
            pointer-events: none;
        }

        body::after {
            content: "";
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at 80% 40%, rgba(14, 165, 233, 0.20), transparent 24%),
                radial-gradient(circle at 15% 48%, rgba(37, 99, 235, 0.15), transparent 26%);
            pointer-events: none;
        }

        .decor-circle {
            position: fixed;
            z-index: 1;
            border-radius: 50%;
            border: 2px solid rgba(14, 165, 233, 0.45);
            background: rgba(3, 16, 43, 0.26);
            box-shadow: 0 0 34px rgba(14, 165, 233, 0.22);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255, 255, 255, 0.86);
            font-size: 34px;
            user-select: none;
        }

        .decor-circle.one {
            width: 120px;
            height: 120px;
            left: 12%;
            top: 23%;
        }

        .decor-circle.two {
            width: 112px;
            height: 112px;
            left: 12%;
            bottom: 18%;
        }

        .decor-circle.three {
            width: 118px;
            height: 118px;
            right: 13%;
            top: 23%;
        }

        .decor-circle.four {
            width: 112px;
            height: 112px;
            right: 17%;
            bottom: 19%;
        }

        .login-wrapper {
            width: min(100%, 520px);
            position: relative;
            z-index: 2;
        }

        .login-card {
            width: 100%;
            background: rgba(255, 255, 255, 0.98);
            border-radius: 8px;
            padding: 32px 32px 34px;
            box-shadow: 0 22px 58px rgba(0, 0, 0, 0.30);
            text-align: center;
        }

        .brand-logo {
            width: 84px;
            height: 84px;
            margin: 0 auto 18px;
            border-radius: 8px;
            background: linear-gradient(145deg, #2563eb, #111827);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 36px;
            font-weight: 900;
            letter-spacing: -0.08em;
            box-shadow: 0 12px 26px rgba(37, 99, 235, 0.25);
        }

        .mini-logo {
            margin: 0 auto 22px;
            width: 64px;
            height: 34px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #15803d;
            font-size: 20px;
            font-weight: 900;
            line-height: 1;
        }

        .portal-title {
            margin: 0;
            color: var(--primary);
            font-size: 32px;
            line-height: 1.1;
            font-weight: 500;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .portal-subtitle {
            margin: 14px 0 26px;
            color: #5d6275;
            font-size: 24px;
            line-height: 1.1;
            font-weight: 500;
        }

        .alert {
            margin: 0 0 18px;
            padding: 12px 14px;
            border-radius: 7px;
            text-align: left;
            font-size: 14px;
            font-weight: 700;
        }

        .alert-error {
            color: var(--danger);
            background: var(--danger-soft);
            border: 1px solid #fecaca;
        }

        .form-group {
            text-align: left;
            margin-bottom: 18px;
        }

        .password-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 8px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #202638;
            font-size: 15px;
            font-weight: 800;
        }

        .password-head label {
            margin-bottom: 0;
        }

        .forgot-label {
            color: var(--primary);
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
        }

        .input-box {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 17px;
            top: 50%;
            transform: translateY(-50%);
            color: #6f7280;
            font-size: 18px;
            pointer-events: none;
        }

        .eye-icon {
            position: absolute;
            right: 17px;
            top: 50%;
            transform: translateY(-50%);
            color: #6f7280;
            font-size: 17px;
            pointer-events: none;
        }

        input {
            width: 100%;
            height: 52px;
            border: 1px solid var(--border);
            border-radius: 7px;
            background: #ffffff;
            outline: none;
            color: var(--text);
            font-size: 18px;
            padding: 0 46px 0 52px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input::placeholder {
            color: #b8becb;
        }

        input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(116, 103, 240, 0.12);
        }

        .submit-btn {
            width: 100%;
            height: 52px;
            border: none;
            border-radius: 7px;
            background: var(--primary);
            color: #ffffff;
            cursor: pointer;
            font-size: 18px;
            font-weight: 800;
            transition: background 0.2s ease, transform 0.2s ease;
        }

        .submit-btn:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

        @media (max-width: 1100px) {
            .decor-circle {
                opacity: 0.55;
                transform: scale(0.86);
            }
        }

        @media (max-width: 820px) {
            body {
                overflow: auto;
            }

            .decor-circle {
                display: none;
            }

            .login-wrapper {
                width: min(100%, 460px);
            }

            .login-card {
                padding: 28px 24px 30px;
            }
        }

        @media (max-width: 520px) {
            body {
                padding: 14px;
                align-items: center;
            }

            .login-wrapper {
                width: 100%;
            }

            .login-card {
                padding: 24px 18px;
                border-radius: 10px;
            }

            .brand-logo {
                width: 72px;
                height: 72px;
                margin-bottom: 14px;
                font-size: 30px;
            }

            .mini-logo {
                margin-bottom: 18px;
            }

            .portal-title {
                font-size: 25px;
            }

            .portal-subtitle {
                margin: 10px 0 20px;
                font-size: 20px;
            }

            label {
                font-size: 14px;
            }

            input,
            .submit-btn {
                height: 48px;
                font-size: 16px;
            }
        }

        @media (max-height: 720px) {
            body {
                overflow: auto;
                align-items: flex-start;
            }

            .login-wrapper {
                margin: 10px 0;
            }

            .login-card {
                padding-top: 24px;
                padding-bottom: 26px;
            }

            .brand-logo {
                width: 70px;
                height: 70px;
                margin-bottom: 12px;
                font-size: 30px;
            }

            .mini-logo {
                margin-bottom: 16px;
            }

            .portal-title {
                font-size: 27px;
            }

            .portal-subtitle {
                margin: 9px 0 20px;
                font-size: 20px;
            }

            .form-group {
                margin-bottom: 14px;
            }

            input,
            .submit-btn {
                height: 48px;
            }
        }
    </style>
</head>

<body>
    <div class="decor-circle one">🔐</div>
    <div class="decor-circle two">📚</div>
    <div class="decor-circle three">🎓</div>
    <div class="decor-circle four">🧾</div>

    <main class="login-wrapper">
        <section class="login-card">
            <div class="brand-logo">
                CS
            </div>

            <div class="mini-logo">
                CoreSystem
            </div>

            <h1 class="portal-title">Administration</h1>
            <p class="portal-subtitle">Authentification</p>

            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/admin/login" method="POST">
                        <%- include('../partials/csrf') %>
                            <div class="form-group">
                                <label for="email">E-mail</label>

                                <div class="input-box">
                                    <span class="input-icon">✉</span>
                                    <input type="email" name="email" id="email" placeholder="E-mail"
                                        autocomplete="email" required autofocus>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="password-head">
                                    <label for="password">Mot de passe</label>
                                    <span class="forgot-label">Mot de passe oublié?</span>
                                </div>

                                <div class="input-box">
                                    <span class="input-icon">🔒</span>
                                    <input type="password" name="password" id="password" placeholder="••••••••••"
                                        autocomplete="current-password" required>
                                    <span class="eye-icon">⊙</span>
                                </div>
                            </div>

                            <button class="submit-btn" type="submit">
                                Connexion
                            </button>
                    </form>
        </section>
    </main>
</body>

</html>