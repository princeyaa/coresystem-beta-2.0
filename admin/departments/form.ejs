<%- include('../../partials/header', {
    title: typeof pageTitle !== 'undefined' ? pageTitle : 'Département',
    session: typeof session !== 'undefined' ? session : null
}) %>

<%
    var d = typeof department !== 'undefined' && department ? department : {};
    var safeCampuses = Array.isArray(campuses) ? campuses : [];
    var isEdit = Boolean(d && d.id);
    var backUrl = '/admin/departments';

    function safeText(value, fallback) {
        if (value === null || typeof value === 'undefined' || value === '') {
            return fallback || '';
        }

        return value;
    }

    function selected(value, expected) {
        return String(value || '') === String(expected || '') ? 'selected' : '';
    }
%>

<div class="cs-back-row">
    <a class="cs-back-link" href="<%= backUrl %>">
        &larr; Retour aux départements
    </a>
</div>

<section class="cs-admin-list-hero">
    <div>
        <span class="page-kicker">Configuration académique</span>

        <h1><%= pageTitle || (isEdit ? 'Modifier le département' : 'Nouveau département') %></h1>

        <p>
            Un département appartient à un campus et sert à organiser les classes, professeurs et espaces académiques.
        </p>
    </div>

    <div class="cs-admin-list-actions">
        <a class="btn btn-secondary" href="/admin/departments">
            Liste départements
        </a>
    </div>
</section>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
<% } %>

<form class="cs-config-form" method="POST" action="<%= formAction %>">
    <%- include('../../partials/csrf') %>

    <section class="cs-form-layout">
        <div class="cs-form-main">
            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Informations département</h2>
                        <p>Code, nom et campus de rattachement.</p>
                    </div>
                </div>

                <div class="cs-form-grid cs-form-grid-2">
                    <div class="cs-form-field">
                        <label for="code">Code *</label>
                        <input id="code" name="code" type="text" value="<%= safeText(d.code, '') %>" placeholder="Ex : INFO" required>
                    </div>

                    <div class="cs-form-field">
                        <label for="nom">Nom *</label>
                        <input id="nom" name="nom" type="text" value="<%= safeText(d.nom, '') %>" placeholder="Ex : Informatique" required>
                    </div>

                    <div class="cs-form-field cs-config-wide-field">
                        <label for="campusId">Campus *</label>
                        <select id="campusId" name="campusId" required>
                            <option value="">Sélectionner un campus</option>

                            <% safeCampuses.forEach(function(campus) { %>
                                <option value="<%= campus.id %>" <%= selected(d.campusId, campus.id) %>>
                                    <%= safeText(campus.nom, 'Campus') %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>
            </article>
        </div>

        <aside class="cs-form-side">
            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">DP</div>
                <h2>Département</h2>
                <p>Ne confonds pas campus et département : Badalabougou est un campus, Informatique est un département.</p>
            </article>

            <article class="cs-form-actions-card">
                <button class="btn btn-primary" type="submit">
                    <%= submitLabel || (isEdit ? 'Enregistrer' : 'Créer le département') %>
                </button>

                <a class="btn btn-secondary" href="<%= backUrl %>">Annuler</a>
            </article>
        </aside>
    </section>
</form>

<%- include('../../partials/footer') %>