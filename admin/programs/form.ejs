<%- include('../../partials/header', {
    title: typeof pageTitle !== 'undefined' ? pageTitle : 'Programme',
    session: typeof session !== 'undefined' ? session : null
}) %>

<%
    var p = typeof program !== 'undefined' && program ? program : {};
    var isEdit = Boolean(p && p.id);
    var backUrl = '/admin/programs';

    function safeText(value, fallback) {
        if (value === null || typeof value === 'undefined' || value === '') {
            return fallback || '';
        }

        return value;
    }

    function selected(value, expected) {
        return String(value || '') === String(expected || '') ? 'selected' : '';
    }
%>

<div class="cs-back-row">
    <a class="cs-back-link" href="<%= backUrl %>">
        &larr; Retour aux programmes
    </a>
</div>

<section class="cs-admin-list-hero">
    <div>
        <span class="page-kicker">Configuration académique</span>

        <h1><%= pageTitle || (isEdit ? 'Modifier le programme' : 'Nouveau programme') %></h1>

        <p>
            Définissez la filière, le niveau, la faculté et le régime. Ce bloc structure les classes,
            les cours et les inscriptions.
        </p>
    </div>

    <div class="cs-admin-list-actions">
        <a class="btn btn-secondary" href="/admin/programs">
            Liste programmes
        </a>
    </div>
</section>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
        <%= error %>
    </div>
<% } %>

<form class="cs-config-form" method="POST" action="<%= formAction %>">
    <%- include('../../partials/csrf') %>

    <section class="cs-form-layout">
        <div class="cs-form-main">
            <article class="cs-form-card">
                <div class="cs-form-card-head">
                    <div>
                        <h2>Informations du programme</h2>
                        <p>Filière, niveau, faculté et régime.</p>
                    </div>
                </div>

                <div class="cs-form-grid cs-form-grid-2">
                    <div class="cs-form-field">
                        <label for="filiere">Filière *</label>
                        <input id="filiere" name="filiere" type="text" value="<%= safeText(p.filiere, '') %>" placeholder="Ex : Informatique" required>
                    </div>

                    <div class="cs-form-field">
                        <label for="niveau">Niveau *</label>
                        <input id="niveau" name="niveau" type="text" value="<%= safeText(p.niveau, '') %>" placeholder="Ex : L2" required>
                    </div>

                    <div class="cs-form-field">
                        <label for="faculte">Faculté</label>
                        <input id="faculte" name="faculte" type="text" value="<%= safeText(p.faculte, '') %>" placeholder="Ex : Sciences et Technologies">
                    </div>

                    <div class="cs-form-field">
                        <label for="regime">Régime</label>
                        <select id="regime" name="regime">
                            <option value="annuel" <%= selected(p.regime || 'annuel', 'annuel') %>>Annuel</option>
                            <option value="semestriel" <%= selected(p.regime, 'semestriel') %>>Semestriel</option>
                        </select>
                    </div>
                </div>
            </article>
        </div>

        <aside class="cs-form-side">
            <article class="cs-form-help-card">
                <div class="cs-form-help-icon">PR</div>
                <h2>Programme</h2>
                <p>Un programme représente une filière et un niveau. Il est utilisé par les classes, les cours et les étudiants.</p>
            </article>

            <article class="cs-form-actions-card">
                <button class="btn btn-primary" type="submit">
                    <%= submitLabel || (isEdit ? 'Enregistrer' : 'Créer le programme') %>
                </button>

                <a class="btn btn-secondary" href="<%= backUrl %>">Annuler</a>
            </article>
        </aside>
    </section>
</form>

<%- include('../../partials/footer') %>